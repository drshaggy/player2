# Player 2 environment variables
#
# Three tiers (see ENGINEERING_PLAN §4):
#   LOCAL    → local Supabase (`supabase start`) — `.env.local` points here
#   PREVIEW  → staging Supabase project — Vercel Preview env vars (§4.4)
#   PROD     → prod Supabase — Vercel Production env vars
#
# This file is committed and documents required keys ONLY. Never put real
# secrets here. Copy to `.env.local` (gitignored) and fill in real values.

# --- Supabase (LOCAL: http://127.0.0.1:54321, key from `supabase status`) ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxx
# Service role key — server-only, never exposed to the client. Required by
# /api/chat to insert assistant messages bypassing RLS.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- LLM (required; stateless — safe to share across tiers) ---
# Any OpenAI-compatible chat completions endpoint works.
LLM_API_KEY=your-llm-api-key
LLM_ENDPOINT=https://your-llm-provider.example.com/v1/chat/completions
LLM_MODEL=your-model-name

# --- Lichess (optional) ---
# The masters opening explorer requires a Bearer token. Without it, the
# pipeline gracefully skips Lichess and falls back to Stockfish candidates.
# Generate one at https://lichess.org/account/preferences/api (free, no scopes needed).
LICHESS_API_TOKEN=
