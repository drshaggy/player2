# Player 2 environment variables
#
# Three tiers (see ENGINEERING_PLAN §4):
#   LOCAL    → local Supabase (`supabase start`) — `.env.local` points here
#   PREVIEW  → staging Supabase project — Vercel Preview env vars (§4.4)
#   PROD     → prod Supabase — Vercel Production env vars
#
# This file is committed and documents required keys ONLY. Never put real
# secrets here. Copy to `.env.local` (gitignored) and fill in real values.

# --- Supabase (LOCAL: http://127.0.0.1:54321, key from `supabase status`) ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxx
# Service role key — server-only, never exposed to the client. Required by
# /api/chat to insert assistant messages bypassing RLS.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- LLM (Cerebras by default; stateless — safe to share across tiers) ---
LLM_API_KEY=your-llm-api-key
LLM_ENDPOINT=https://api.cerebras.ai/v1/chat/completions
LLM_MODEL=gemma-4-31b
